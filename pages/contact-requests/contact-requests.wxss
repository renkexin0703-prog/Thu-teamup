.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 16rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  border-radius: 20rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.empty-container {
  padding: 100rpx 0;
  text-align: center;
}

.generate-btn {
  margin-top: 40rpx;
  width: 80%;
  border-radius: 24rpx;
}

.contacts-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.total-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.last-update {
  font-size: 24rpx;
  color: #999;
}

.contact-cell {
  padding: 16rpx 0;
}

.avatar-container {
  position: relative;
  margin-right: 16rpx;
}

.online-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  background-color: #07c160;
  border: 4rpx solid #fff;
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.grade-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.user-dept {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.skills-container {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.skill-tag {
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.contact-time {
  font-size: 24rpx;
  color: #999;
}

.wechat-info {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.wechat-text {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #07c160;
}

.swipe-right-actions {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.swipe-right-actions .van-button {
  flex: 1;
  height: 100%;
  border-radius: 0;
}

.footer-tip {
  margin-top: 24rpx;
  padding: 16rpx;
  background-color: #f0f9ff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
}

.tip-text {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .page-header {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .refresh-section {
    margin-top: 12rpx;
  }
  
  .user-name-row {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .grade-tag {
    margin-top: 8rpx;
  }
}
