.card-container {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(103, 119, 239, 0.1);
  background: #fff;
  height: 220rpx;
}

.post-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  opacity: 0.8; /* 让背景图稍微淡一点，突出文字 */
}

.card-content {
  position: relative;
  z-index: 2;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
}

.purple-btn {
  background: linear-gradient(135deg, #6777ef, #8e9eff);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}