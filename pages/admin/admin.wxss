/* pages/admin/admin.wxss */
.container { padding: 30rpx; background: #f7f7f7; min-height: 100vh; }
.header { margin-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.subtitle { font-size: 24rpx; color: #888; margin-top: 10rpx; }

.input-section { background: #fff; padding: 20rpx; border-radius: 12rpx; margin-bottom: 30rpx; }
.url-input { width: 100%; height: 160rpx; font-size: 28rpx; margin-bottom: 20rpx; }

.result-card { background: #fff; padding: 30rpx; border-radius: 16rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); }
.form-item { margin-bottom: 30rpx; border-bottom: 1rpx solid #eee; padding-bottom: 10rpx; }
.label { font-size: 24rpx; color: #999; display: block; margin-bottom: 10rpx; }
.value { font-size: 30rpx; color: #333; width: 100%; }
.value-text { font-size: 28rpx; color: #666; width: 100%; height: 150rpx; }

.save-btn { background: #07c160; color: #fff; border-radius: 50rpx; margin-top: 40rpx; }