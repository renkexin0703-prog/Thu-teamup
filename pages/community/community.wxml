<view class="container">
  <view class="header-section">
    <view class="brand-logo">
      <text class="logo-main">社区组队</text>
      <text class="logo-badge">THU</text>
    </view>
    
    <view class="filter-box">
      <view class="filter-row">
        <text class="f-label">性别</text>
        <scroll-view scroll-x class="f-scroll">
          <view wx:for="{{filterOptions.gender}}" wx:key="*this" 
                class="f-tag {{currentFilter.gender == item ? 'active' : ''}}" 
                bindtap="onGenderChange" data-index="{{index}}">{{item}}</view>
        </scroll-view>
      </view>
      <view class="filter-row">
        <text class="f-label">年级</text>
        <scroll-view scroll-x class="f-scroll">
          <view wx:for="{{filterOptions.grades}}" wx:key="*this" 
                class="f-tag {{currentFilter.grade == item ? 'active' : ''}}" 
                bindtap="onGradeChange" data-index="{{index}}">{{item}}</view>
        </scroll-view>
        <text class="reset-link" bindtap="resetFilters">重置</text>
      </view>
    </view>
  </view>

  <view class="post-list">
    <view wx:if="{{filteredTeamUpPosts.length === 0}}" class="empty-tip">
      <view>暂无匹配的组队需求</view>
    </view>

    <block wx:for="{{filteredTeamUpPosts}}" wx:key="id">
      <view class="post-card">
        <view class="post-tags-top">
          <text class="category-tag">组队招募</text>
          <view class="target-badge" wx:if="{{item.targetGrades}}">招：{{item.targetGrades}}</view>
        </view>

        <view class="post-header">
          <image class="avatar" src="{{item.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="user-info">
            <view class="user-name">{{item.userName}}</view>
            <view class="user-meta">{{item.userDepartment || '清华大学'}} · {{item.userGrade}}</view>
          </view>
        </view>

        <view class="post-body">
          <view class="post-title">{{item.title}}</view>
          <view class="post-desc">{{item.content}}</view>
          
          <view class="skill-tags">
            <text class="s-tag" wx:for="{{item.targetSkills}}" wx:for-item="skill" wx:key="*this"># {{skill}}</text>
          </view>
        </view>

        <view class="post-footer">
          <view class="time-hint"> </view> 
          <view class="footer-btns">
            <block wx:if="{{item.isOwnPost}}">
              <view class="mini-btn btn-primary" bindtap="onSelectMember" data-post-id="{{item._id || item.id}}">管理组队</view>
            </block>
            <block wx:else>
              <view class="mini-btn btn-secondary" bindtap="onKnowTA" data-user-id="{{item.userId}}">了解TA</view>
              <view class="mini-btn btn-primary" bindtap="onContactTA" 
      data-id="{{item._id || item.id}}" 
      data-wechat="{{item.contactWechat || ''}}"
      data-user-id="{{item.userId}}">联系TA</view>
            </block>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="fab-btn" bindtap="gotoPublishTeamUp">+</view>
</view>