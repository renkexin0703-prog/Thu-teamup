page {
  background-color: #f7f8fa;
}

.header-section {
  background: #fff;
  padding: 40rpx 30rpx 30rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: 20rpx;
}

.brand-logo {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.logo-main {
  font-size: 46rpx;
  font-weight: 800;
  color: #6777ef;
  background: linear-gradient(120deg, #6777ef, #8e9eff);
  -webkit-background-clip: text;
  color: transparent;
}

.logo-badge {
  font-size: 18rpx;
  background: #6777ef;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 15rpx;
  font-weight: bold;
}

/* 筛选区优化 */
.f-tag {
  display: inline-block;
  padding: 8rpx 28rpx;
  background: #f1f3f8;
  color: #666;
  font-size: 24rpx;
  border-radius: 30rpx;
  margin-right: 15rpx;
  transition: 0.3s;
}

.f-tag.active {
  background: #6777ef;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(103, 119, 239, 0.3);
}

/* 帖子卡片增强 */
.post-card {
  background: #fff;
  margin: 24rpx 30rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05);
}

.post-tags-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.category-tag {
  font-size: 20rpx;
  color: #6777ef;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.target-badge {
  font-size: 20rpx;
  color: #ff7675;
  background: rgba(255, 118, 117, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.post-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f2ff;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3436;
}

.post-title {
  font-size: 34rpx;
  color: #2d3436;
  margin: 24rpx 0 16rpx;
}

.post-desc {
  font-size: 28rpx;
  color: #636e72;
  margin-bottom: 24rpx;
}

/* 标签颜色加深 */
.s-tag {
  font-size: 22rpx;
  color: #6777ef;
  background: #f0f2ff;
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #f1f3f8;
}

.time-hint {
  font-size: 22rpx;
  color: #b2bec3;
}

.footer-btns {
  display: flex;
  gap: 16rpx;
}

.mini-btn {
  padding: 14rpx 36rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 100rpx;
}

.btn-primary { background: #6777ef; color: #fff; }
.btn-secondary { background: #fff; color: #6777ef; border: 2rpx solid #6777ef; }

.fab-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6777ef, #8e9eff);
  font-size: 60rpx;
  box-shadow: 0 10rpx 25rpx rgba(103, 119, 239, 0.4);
}
