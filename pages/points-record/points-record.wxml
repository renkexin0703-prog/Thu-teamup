<!-- 加载状态 -->
<view class="loading" wx:if="{{loading}}">
  <van-loading type="spinner" size="32px" />
  <text class="loading-text">加载中...</text>
</view>

<!-- 积分记录 -->
<view class="card" wx:else>
  <view class="card-header">当前积分：{{userInfo.points}}</view>
  <view class="record-list" wx:if="{{userInfo.pointsRecord.length > 0}}">
    <block wx:for="{{userInfo.pointsRecord}}" wx:key="time">
      <view class="record-item">
        <view class="record-left">
          <view class="record-type">{{item.type}}</view>
          <view class="record-desc">{{item.desc}}</view>
          <view class="record-time">{{item.time}}</view>
        </view>
        <view class="record-points {{item.points > 0 ? 'gain' : 'cost'}}">
          {{item.points > 0 ? '+' : ''}}{{item.points}}
        </view>
      </view>
    </block>
  </view>
  <view class="empty-tips" wx:else>
    <text>暂无积分记录</text>
  </view>
</view>