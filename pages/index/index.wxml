<view class="container" wx:if="{{!hasUserInfo}}">
  <button class="login-btn" bindtap="getUserProfile">点击授权登录</button>
</view>

<view class="header-section">
  <view class="brand-logo">
    <text class="logo-main">清组队</text>
    <text class="logo-badge">THU</text>
  </view>
  <view class="brand-slogan">最靠谱的校园组队平台</view>
</view>

<view class="activity-list">
  <block wx:for="{{allActivities}}" wx:key="_id">
    <view class="activity-card">
      <view class="card-body">
        <view class="main-title">{{item.title}}</view>
        
        <view class="info-grid">
          <view class="info-item">
            <text class="label">主办：</text>
            <text class="value">{{item.organizer || '清华大学'}}</text>
          </view>
          <view class="info-item">
            <text class="label">截止：</text>
            <text class="value">{{item.deadline}}</text>
          </view>
        </view>
      </view>
      
      <view class="card-actions">
        <view class="mini-btn btn-plain" 
              bindtap="onPopupDetail" 
              data-id="{{item._id}}" 
              data-activity="{{item}}">
          查看详情
        </view>

        <view class="mini-btn btn-filled" 
              bindtap="onQuickTeamUp" 
              data-id="{{item._id}}">
          一键组队
        </view>
      </view>
    </view>
  </block>
</view>