/* 页面基础 */
page {
  background-color: #f6f7fb;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* --- 顶部 Logo 设计 --- */
.header-section {
  padding: 60rpx 40rpx 30rpx;
  background: white;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: 20rpx;
}

.brand-logo {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.logo-main {
  font-size: 44rpx;
  font-weight: 800;
  color: #6777ef;
  letter-spacing: 2rpx;
}

.logo-badge {
  font-size: 18rpx;
  background: #6777ef;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 15rpx;
  font-weight: bold;
}

.brand-slogan {
  font-size: 24rpx;
  color: #99a2aa;
  letter-spacing: 1rpx;
}

/* --- 活动卡片精修 --- */
.activity-card {
  background: #ffffff;
  margin: 24rpx 30rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(103, 119, 239, 0.06);
}

.main-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-item {
  font-size: 24rpx;
  display: flex;
}

.label {
  color: #95a5a6;
  width: 80rpx;
}

.value {
  color: #34495e;
  flex: 1;
}

/* --- 胶囊小按钮设计 --- */
.card-actions {
  display: flex;
  justify-content: flex-end; /* 按钮向右靠拢 */
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f8f9fa;
  gap: 16rpx;
}

.mini-btn {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 100rpx; /* 胶囊圆角 */
  transition: all 0.2s;
}

.btn-filled {
  background: #6777ef;
  color: #fff;
}

.btn-plain {
  background: #f0f2ff;
  color: #6777ef;
  border: 1rpx solid #d0d7ff;
}

.mini-btn:active {
  transform: scale(0.96);
  opacity: 0.8;
}

/* 隐藏不必要的登录按钮占位 */
.login-btn {
  background: #6777ef;
  color: white;
  margin: 40rpx;
  border-radius: 45rpx;
}