<!-- pages/select-teammates/select-teammates.wxml -->
<view class="container">
  <view class="header">选择队友</view>

  <!-- 申请人列表 -->
  <checkbox-group bindchange="onApplicantSelect">
    <block wx:for="{{applicants}}" wx:key="userId">
      <label class="applicant-item">
        <checkbox value="{{index}}" />
        {{item.userName}} 
        
      </label>
    </block>
  </checkbox-group>

  <!-- 空状态提示 -->
  <view wx:if="{{applicants.length === 0}}" class="empty-tip">
    暂无申请人
  </view>

  <!-- 组队成功按钮 -->
  <view class="btn" bindtap="onTeamUpSuccess">组队成功</view>
  <!-- 新增提示文字 -->
  <view class="tip-text">
    组队成功后，您的帖子将会下架，请保证您与合适的队友已有联系。
  </view>
</view>